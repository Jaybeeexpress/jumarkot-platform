# =============================================================================
# Jumarkot Platform – .gitignore
# =============================================================================

# ── Gradle ────────────────────────────────────────────────────────────────────
.gradle/
**/build/
!**/src/main/**/build/
!**/src/test/**/build/
gradle-app.setting
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
*.gradle.bak

# ── Maven (if ever used) ──────────────────────────────────────────────────────
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# ── Java ──────────────────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ── Kotlin ────────────────────────────────────────────────────────────────────
*.kotlin_module

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
dist/
.next/
.nuxt/
.output/

# ── IDEs ─────────────────────────────────────────────────────────────────────
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Eclipse
.classpath
.project
.settings/
.loadpath

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# NetBeans
nbproject/private/
nbbuild/
nbdist/
nbactions.xml
nb-configuration.xml

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ── Linux ─────────────────────────────────────────────────────────────────────
*~

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/

# ── Secrets / Environment ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key
*.p12
*.jks
*.keystore
*.truststore
secrets/

# ── Docker ────────────────────────────────────────────────────────────────────
docker/.env

# ── Test artifacts ────────────────────────────────────────────────────────────
**/test-results/
**/reports/
**/jacoco/
*.exec
*.ec

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
spring.log

# ── Generated code ────────────────────────────────────────────────────────────
**/generated/
**/generated-sources/
**/generated-test-sources/
