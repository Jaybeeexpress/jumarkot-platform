{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.jumarkot.com/events/onboarding.event.json",
  "title": "OnboardingEvent",
  "description": "Represents a user or business onboarding event (KYC/KYB initiation, document submission, identity verification result) submitted for compliance and fraud screening.",
  "type": "object",
  "required": [
    "onboardingId",
    "entityId",
    "entityType",
    "stage",
    "stageStatus",
    "occurredAt"
  ],
  "additionalProperties": false,
  "properties": {
    "onboardingId": {
      "type": "string",
      "description": "Caller-assigned unique identifier for the onboarding session or flow.",
      "minLength": 1,
      "maxLength": 256
    },
    "entityId": {
      "type": "string",
      "description": "Identifier of the user or business being onboarded.",
      "minLength": 1,
      "maxLength": 256
    },
    "entityType": {
      "type": "string",
      "description": "Whether the subject is an individual consumer (KYC) or a business entity (KYB).",
      "enum": ["INDIVIDUAL", "BUSINESS"]
    },
    "stage": {
      "type": "string",
      "description": "The current onboarding stage that this event reports on.",
      "enum": [
        "REGISTRATION",
        "EMAIL_VERIFICATION",
        "PHONE_VERIFICATION",
        "DOCUMENT_UPLOAD",
        "DOCUMENT_REVIEW",
        "BIOMETRIC_CHECK",
        "SANCTIONS_SCREENING",
        "PEP_SCREENING",
        "ADVERSE_MEDIA_SCREENING",
        "RISK_SCORING",
        "MANUAL_REVIEW",
        "APPROVAL",
        "REJECTION"
      ]
    },
    "stageStatus": {
      "type": "string",
      "description": "Outcome of the reported stage.",
      "enum": [
        "INITIATED",
        "IN_PROGRESS",
        "COMPLETED",
        "FAILED",
        "PENDING_USER_ACTION",
        "PENDING_MANUAL_REVIEW",
        "EXPIRED"
      ]
    },
    "individual": {
      "type": "object",
      "description": "Personal details for INDIVIDUAL entity type.",
      "additionalProperties": false,
      "properties": {
        "firstName": {
          "type": "string",
          "maxLength": 100
        },
        "lastName": {
          "type": "string",
          "maxLength": 100
        },
        "dateOfBirth": {
          "type": "string",
          "description": "ISO 8601 date of birth.",
          "format": "date"
        },
        "nationalityCode": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 nationality/citizenship code.",
          "pattern": "^[A-Z]{2}$"
        },
        "residenceCountryCode": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "taxIdentificationNumber": {
          "type": "string",
          "description": "Hashed or tokenized tax ID. Must never be transmitted in plaintext.",
          "maxLength": 256
        }
      }
    },
    "business": {
      "type": "object",
      "description": "Business details for BUSINESS entity type.",
      "additionalProperties": false,
      "properties": {
        "legalName": {
          "type": "string",
          "maxLength": 255
        },
        "tradingName": {
          "type": "string",
          "maxLength": 255
        },
        "registrationNumber": {
          "type": "string",
          "maxLength": 128
        },
        "incorporationCountryCode": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "incorporationDate": {
          "type": "string",
          "format": "date"
        },
        "businessType": {
          "type": "string",
          "enum": [
            "SOLE_TRADER",
            "PARTNERSHIP",
            "LIMITED_COMPANY",
            "PUBLIC_COMPANY",
            "NON_PROFIT",
            "GOVERNMENT",
            "TRUST",
            "OTHER"
          ]
        },
        "websiteUrl": {
          "type": "string",
          "format": "uri",
          "maxLength": 2048
        }
      }
    },
    "documents": {
      "type": "array",
      "description": "Identity or business documents submitted during this onboarding stage.",
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["documentId", "documentType", "status"],
        "additionalProperties": false,
        "properties": {
          "documentId": {
            "type": "string",
            "description": "Platform-assigned identifier for the document record.",
            "maxLength": 256
          },
          "documentType": {
            "type": "string",
            "enum": [
              "PASSPORT",
              "NATIONAL_ID",
              "DRIVERS_LICENSE",
              "RESIDENCE_PERMIT",
              "UTILITY_BILL",
              "BANK_STATEMENT",
              "CERTIFICATE_OF_INCORPORATION",
              "ARTICLES_OF_ASSOCIATION",
              "TAX_CERTIFICATE",
              "OTHER"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["SUBMITTED", "UNDER_REVIEW", "ACCEPTED", "REJECTED", "EXPIRED"]
          },
          "issuingCountryCode": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          },
          "expiryDate": {
            "type": "string",
            "format": "date"
          },
          "rejectionReason": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    },
    "screeningResults": {
      "type": "array",
      "description": "Compliance screening results produced during this onboarding event.",
      "items": {
        "type": "object",
        "required": ["screeningType", "outcome"],
        "additionalProperties": false,
        "properties": {
          "screeningType": {
            "type": "string",
            "enum": ["SANCTIONS", "PEP", "ADVERSE_MEDIA", "FRAUD_LIST", "CUSTOM_LIST"]
          },
          "outcome": {
            "type": "string",
            "enum": ["CLEAR", "POTENTIAL_MATCH", "CONFIRMED_MATCH", "ERROR"]
          },
          "matchScore": {
            "type": "number",
            "description": "Confidence score of the match in range [0.0, 1.0].",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "listSources": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 100
            },
            "description": "Names of the lists that produced the match (e.g. OFAC SDN, EU Consolidated)."
          }
        }
      }
    },
    "channel": {
      "type": "string",
      "description": "Channel through which the onboarding was initiated.",
      "enum": ["WEB", "MOBILE_IOS", "MOBILE_ANDROID", "API", "BRANCH", "PARTNER"]
    },
    "ipAddress": {
      "type": "string",
      "format": "ipv4"
    },
    "referralSource": {
      "type": "string",
      "description": "Attribution code or UTM source identifying where the applicant came from.",
      "maxLength": 256
    },
    "metadata": {
      "type": "object",
      "description": "Arbitrary key-value pairs for tenant-specific enrichment.",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      },
      "maxProperties": 100
    },
    "occurredAt": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp of when this onboarding event occurred.",
      "format": "date-time"
    }
  }
}
