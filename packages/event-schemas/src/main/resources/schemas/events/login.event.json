{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.jumarkot.com/events/login.event.json",
  "title": "LoginEvent",
  "description": "Represents an authentication attempt (successful or failed) submitted for account-takeover and anomaly detection.",
  "type": "object",
  "required": [
    "attemptId",
    "userId",
    "outcome",
    "authMethod",
    "occurredAt"
  ],
  "additionalProperties": false,
  "properties": {
    "attemptId": {
      "type": "string",
      "description": "Caller-assigned unique identifier for this authentication attempt.",
      "minLength": 1,
      "maxLength": 256
    },
    "userId": {
      "type": "string",
      "description": "Platform identifier of the user attempting to authenticate.",
      "minLength": 1,
      "maxLength": 256
    },
    "outcome": {
      "type": "string",
      "description": "Result of the authentication attempt.",
      "enum": [
        "SUCCESS",
        "FAILED_WRONG_PASSWORD",
        "FAILED_WRONG_OTP",
        "FAILED_BIOMETRIC",
        "FAILED_ACCOUNT_LOCKED",
        "FAILED_UNKNOWN",
        "STEP_UP_REQUIRED",
        "BLOCKED_BY_POLICY"
      ]
    },
    "authMethod": {
      "type": "string",
      "description": "The primary authentication method presented.",
      "enum": [
        "PASSWORD",
        "PASSKEY",
        "BIOMETRIC_FACE",
        "BIOMETRIC_FINGERPRINT",
        "SMS_OTP",
        "EMAIL_OTP",
        "TOTP",
        "PUSH_NOTIFICATION",
        "HARDWARE_KEY",
        "SOCIAL_OAUTH"
      ]
    },
    "stepUpMethod": {
      "type": "string",
      "description": "Second factor used in multi-factor flows, if any.",
      "enum": [
        "SMS_OTP",
        "EMAIL_OTP",
        "TOTP",
        "PUSH_NOTIFICATION",
        "HARDWARE_KEY",
        "BIOMETRIC_FACE",
        "BIOMETRIC_FINGERPRINT"
      ]
    },
    "channel": {
      "type": "string",
      "description": "Application channel through which the login was attempted.",
      "enum": ["WEB", "MOBILE_IOS", "MOBILE_ANDROID", "API", "SSO"]
    },
    "ipAddress": {
      "type": "string",
      "description": "IPv4 address of the client.",
      "format": "ipv4"
    },
    "ipAddressV6": {
      "type": "string",
      "description": "IPv6 address of the client.",
      "format": "ipv6"
    },
    "userAgent": {
      "type": "string",
      "description": "HTTP User-Agent string of the client browser or app.",
      "maxLength": 1024
    },
    "deviceFingerprint": {
      "type": "string",
      "description": "Hashed, privacy-preserving device fingerprint.",
      "maxLength": 512
    },
    "deviceTrustScore": {
      "type": "number",
      "description": "Client-provided device trust score in range [0.0, 1.0], if available.",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "sessionId": {
      "type": "string",
      "description": "Application session ID established after successful login.",
      "maxLength": 256
    },
    "geolocation": {
      "type": "object",
      "description": "Geographic location inferred from the client IP.",
      "required": ["countryCode"],
      "additionalProperties": false,
      "properties": {
        "countryCode": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "regionCode": {
          "type": "string",
          "maxLength": 10
        },
        "city": {
          "type": "string",
          "maxLength": 100
        },
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "isVpn": {
          "type": "boolean",
          "description": "Whether the IP is associated with a known VPN exit node."
        },
        "isTor": {
          "type": "boolean",
          "description": "Whether the IP is a known Tor exit node."
        },
        "isDatacenter": {
          "type": "boolean",
          "description": "Whether the IP belongs to a datacenter or cloud provider range."
        }
      }
    },
    "failedAttemptCount": {
      "type": "integer",
      "description": "Number of consecutive failed attempts for this user prior to this event.",
      "minimum": 0
    },
    "metadata": {
      "type": "object",
      "description": "Arbitrary key-value pairs for tenant-specific enrichment signals.",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      },
      "maxProperties": 100
    },
    "occurredAt": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp of the authentication attempt.",
      "format": "date-time"
    }
  }
}
