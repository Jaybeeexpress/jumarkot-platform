# =============================================================================
# Jumarkot Platform — Environment Variables
# Copy this file to .env and fill in values before running locally.
# NEVER commit .env to source control.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jumarkot
POSTGRES_PASSWORD=jumarkot_dev_secret
# Canonical aliases used by decision-engine and CI
DB_USERNAME=jumarkot
DB_PASSWORD=jumarkot_dev_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=jumarkot_redis_secret

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ─── JWT signing ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_BEFORE_RUNNING

# ─── identity-access-service ─────────────────────────────────────────────────
IDENTITY_SERVICE_PORT=8081
IDENTITY_DB_URL=jdbc:postgresql://localhost:5432/identity_db
IDENTITY_SERVICE_URL=http://localhost:8081
IDENTITY_SERVICE_USER=admin
IDENTITY_SERVICE_PASSWORD=changeme

# ─── tenant-service ───────────────────────────────────────────────────────────
TENANT_SERVICE_PORT=8082
TENANT_DB_URL=jdbc:postgresql://localhost:5432/tenant_db
TENANT_SERVICE_URL=http://localhost:8082
TENANT_SERVICE_USER=admin
TENANT_SERVICE_PASSWORD=changeme

# ─── billing-entitlements-service ─────────────────────────────────────────────
BILLING_SERVICE_PORT=8083
BILLING_DB_URL=jdbc:postgresql://localhost:5432/billing_db

# ─── event-ingestion-service ──────────────────────────────────────────────────
INGESTION_SERVICE_PORT=8084
INGESTION_DB_URL=jdbc:postgresql://localhost:5432/ingestion_db
EVENT_INGESTION_SERVICE_URL=http://localhost:8084
EVENT_INGESTION_TOPIC=events.ingested

# ─── decision-engine-service ──────────────────────────────────────────────────
DECISION_SERVICE_PORT=8085
DECISION_DB_URL=jdbc:postgresql://localhost:5432/decision_db
RULES_SERVICE_URL=http://localhost:8087
# Backward-compatible alias (optional)
RULES_SERVICE_BASE_URL=http://localhost:8087
RULES_SERVICE_CONNECT_TIMEOUT=2s
RULES_SERVICE_READ_TIMEOUT=5s
RULES_SERVICE_BLOCK_TIMEOUT=6s

# ─── rules-service ────────────────────────────────────────────────────────────
RULES_SERVICE_PORT=8087
RULES_DB_URL=jdbc:postgresql://localhost:5432/rules_db

# ─── entity-profile-service ───────────────────────────────────────────────────
ENTITY_SERVICE_PORT=8088
ENTITY_DB_URL=jdbc:postgresql://localhost:5432/entity_db

# ─── alert-case-service ───────────────────────────────────────────────────────
CASE_SERVICE_PORT=8089
CASE_DB_URL=jdbc:postgresql://localhost:5432/case_db

# ─── developer-platform-service ───────────────────────────────────────────────
DEVELOPER_SERVICE_PORT=8091
DEVELOPER_DB_URL=jdbc:postgresql://localhost:5432/developer_db
