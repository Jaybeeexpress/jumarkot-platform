# =============================================================================
# Jumarkot Platform – Local Development Environment Variables
# Copy this file to .env and populate with your local values.
# NEVER commit a populated .env file to source control.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=jumarkot
POSTGRES_PASSWORD=jumarkot_dev_secret
POSTGRES_PORT=5432

# Individual service JDBC URLs (for use in service application.properties)
JDBC_IAM=jdbc:postgresql://localhost:5432/jumarkot_iam
JDBC_TENANTS=jdbc:postgresql://localhost:5432/jumarkot_tenants
JDBC_EVENTS=jdbc:postgresql://localhost:5432/jumarkot_events
JDBC_DECISIONS=jdbc:postgresql://localhost:5432/jumarkot_decisions
JDBC_RULES=jdbc:postgresql://localhost:5432/jumarkot_rules
JDBC_CASES=jdbc:postgresql://localhost:5432/jumarkot_cases

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=jumarkot_redis_secret
REDIS_URL=redis://:jumarkot_redis_secret@localhost:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_PORT=29092
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ── Schema Registry ───────────────────────────────────────────────────────────
SCHEMA_REGISTRY_PORT=8081
SCHEMA_REGISTRY_URL=http://localhost:8081
